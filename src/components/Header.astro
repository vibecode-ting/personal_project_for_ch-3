---
import LanguageSwitcher from './LanguageSwitcher';
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const navLinks = [
  { key: 'nav.home', href: `/${lang}` },
  { key: 'nav.features', href: `/${lang}#features` },
  { key: 'nav.builder', href: `/${lang}/builder` },
  { key: 'nav.docs', href: `/${lang}/docs` },
  { key: 'nav.contact', href: `/${lang}/contact` },
];
---

<header class="sticky top-0 z-50 w-full" id="site-header">
  <!-- Glass-morphism background -->
  <div class="absolute inset-0 bg-white/70 dark:bg-slate-950/70 backdrop-blur-xl border-b border-slate-200/60 dark:border-slate-800/60"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 lg:h-18">
      <!-- Logo -->
      <a href={`/${lang}`} class="flex items-center gap-2.5 group" aria-label="Home">
        <div class="w-9 h-9 bg-gradient-to-br from-blue-500 via-purple-500 to-pink-500 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/25 group-hover:shadow-blue-500/40 group-hover:scale-105 transition-all duration-300">
          <span class="text-white font-extrabold text-lg">S</span>
        </div>
        <div class="hidden sm:block">
          <h1 class="text-base font-bold text-slate-900 dark:text-white leading-tight">
            Static Builder
          </h1>
          <p class="text-[10px] text-slate-500 dark:text-slate-400 leading-tight">
            myanmardev.com
          </p>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-950/50 transition-all duration-200"
          >
            {t(lang, link.key)}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <LanguageSwitcher client:load currentLang={lang} onLanguageChange={() => {}} />

        <!-- CTA Button -->
        <a
          href={`/${lang}/builder`}
          class="hidden sm:inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-sm font-semibold rounded-lg hover:shadow-lg hover:shadow-blue-500/25 hover:scale-[1.03] transition-all duration-300"
        >
          Get Started
          <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur-xl">
    <nav class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2.5 text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-950/50 transition-all"
        >
          {t(lang, link.key)}
        </a>
      ))}
      <a
        href={`/${lang}/builder`}
        class="block mt-3 px-4 py-2.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-sm font-semibold text-center rounded-lg hover:shadow-lg transition-all"
      >
        Get Started
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Close menu on route change
  document.addEventListener('astro:page-load', () => {
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  });
</script>

<style>
  header {
    animation: slideDown 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
