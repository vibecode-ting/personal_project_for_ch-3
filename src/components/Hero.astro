---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden pt-20 sm:pt-28 lg:pt-36 pb-20 sm:pb-28">
  <!-- Animated background orbs -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-[-20%] right-[-10%] h-[600px] w-[600px] rounded-full bg-gradient-to-br from-blue-400/30 via-purple-400/20 to-pink-400/30 blur-3xl animate-pulse" style="animation-duration: 8s;"></div>
    <div class="absolute bottom-[-20%] left-[-10%] h-[500px] w-[500px] rounded-full bg-gradient-to-tr from-blue-400/20 via-purple-400/30 to-pink-400/20 blur-3xl animate-pulse" style="animation-duration: 10s; animation-delay: 2s;"></div>
    <div class="absolute top-[40%] left-[30%] h-[300px] w-[300px] rounded-full bg-gradient-to-r from-blue-300/20 to-purple-300/20 blur-3xl animate-pulse" style="animation-duration: 12s; animation-delay: 4s;"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.03)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>
  </div>

  <!-- Badge -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-50 dark:bg-blue-950/50 border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 text-sm font-medium mb-8 animate-fade-in-up">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
      </span>
      Now available on GitHub Pages
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <!-- Main heading -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-6 leading-[1.1] animate-fade-in-up">
        Build <span class="text-gradient">Static Sites</span>
        <br class="hidden sm:block" />
        Faster Than Ever
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl lg:text-2xl text-slate-600 dark:text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed animate-fade-in-up" style="animation-delay: 0.1s">
        Create professional, blazing-fast static websites with our intuitive builder.
        Firebase-powered, SEO-optimized, and ready to deploy in minutes.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.2s">
        <a
          href={`/${lang}/builder`}
          class="group px-8 py-4 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 text-white font-semibold text-lg rounded-xl hover:shadow-2xl hover:shadow-blue-500/30 hover:scale-[1.03] transition-all duration-300 inline-flex items-center gap-2"
        >
          Start Building Free
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a
          href={`/${lang}/docs`}
          class="px-8 py-4 border-2 border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-200 font-semibold text-lg rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 hover:border-slate-400 dark:hover:border-slate-500 transition-all duration-300"
        >
          View Docs
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 lg:mt-20 grid grid-cols-2 md:grid-cols-4 gap-8 max-w-3xl mx-auto animate-fade-in-up" style="animation-delay: 0.3s">
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-1">10k+</div>
          <div class="text-sm text-slate-500 dark:text-slate-400">Sites Built</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-1">99</div>
          <div class="text-sm text-slate-500 dark:text-slate-400">Lighthouse Score</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-1">0.8s</div>
          <div class="text-sm text-slate-500 dark:text-slate-400">Avg Load Time</div>
        </div>
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-1">24/7</div>
          <div class="text-sm text-slate-500 dark:text-slate-400">Support</div>
        </div>
      </div>

      <!-- Hero illustration / screenshot mockup -->
      <div class="mt-16 lg:mt-20 animate-fade-in-up" style="animation-delay: 0.4s">
        <div class="relative max-w-5xl mx-auto">
          <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl blur-2xl opacity-20"></div>
          <div class="relative bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden">
            <!-- Mock browser bar -->
            <div class="flex items-center gap-2 px-4 py-3 bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
              <div class="ml-3 flex-1 bg-white dark:bg-slate-800 rounded-md px-3 py-1 text-xs text-slate-400">myanmardev.com</div>
            </div>
            <!-- Mock content -->
            <div class="p-6 sm:p-10">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="h-32 bg-gradient-to-br from-blue-100 to-blue-50 dark:from-blue-950 dark:to-blue-900 rounded-xl flex items-center justify-center border border-blue-200 dark:border-blue-800">
                  <span class="text-blue-600 dark:text-blue-400 font-semibold text-sm">Portfolio</span>
                </div>
                <div class="h-32 bg-gradient-to-br from-purple-100 to-purple-50 dark:from-purple-950 dark:to-purple-900 rounded-xl flex items-center justify-center border border-purple-200 dark:border-purple-800">
                  <span class="text-purple-600 dark:text-purple-400 font-semibold text-sm">Business</span>
                </div>
                <div class="h-32 bg-gradient-to-br from-pink-100 to-pink-50 dark:from-pink-950 dark:to-pink-900 rounded-xl flex items-center justify-center border border-pink-200 dark:border-pink-800">
                  <span class="text-pink-600 dark:text-pink-400 font-semibold text-sm">Blog</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
