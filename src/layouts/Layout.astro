---
import Header from '../components/Header.astro';
import { type Language } from '../i18n/utils';

interface Props {
  title: string;
  lang: Language;
  description?: string;
  ogImage?: string;
}

const { title, lang, description, ogImage } = Astro.props;
const siteUrl = 'https://myanmardev.com';
const metaDescription = description || 'Create beautiful static websites in minutes with our powerful static site builder. Firebase-powered, SEO-optimized, and production-ready.';
const ogImageUrl = ogImage || `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#3b82f6" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Static Sites Builder" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 antialiased">
    <Header lang={lang} />
    <main class="min-h-screen">
      <slot />
    </main>
    <footer class="relative border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900">
      <!-- Decorative gradient -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-px bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-50"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12 mb-12">
          <!-- Brand -->
          <div class="lg:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                <span class="text-white font-bold text-xl">S</span>
              </div>
              <div>
                <h3 class="font-bold text-lg text-slate-900 dark:text-white">Static Builder</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400">by myanmardev.com</p>
              </div>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 max-w-xs leading-relaxed">
              Build lightning-fast static websites with our intuitive builder. Deploy to GitHub Pages in minutes.
            </p>
            <div class="flex items-center gap-3">
              <a href="https://github.com/vibecode-ting/personal_project_for_ch-3"
                 class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors"
                 aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
          </div>

          <!-- Product -->
          <div>
            <h4 class="font-semibold text-slate-900 dark:text-white mb-4 text-sm uppercase tracking-wider">Product</h4>
            <ul class="space-y-3">
              <li><a href="#features" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Features</a></li>
              <li><a href="/builder" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Builder</a></li>
              <li><a href="/docs" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Documentation</a></li>
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h4 class="font-semibold text-slate-900 dark:text-white mb-4 text-sm uppercase tracking-wider">Company</h4>
            <ul class="space-y-3">
              <li><a href="#" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">About</a></li>
              <li><a href="#" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Blog</a></li>
              <li><a href="/contact" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h4 class="font-semibold text-slate-900 dark:text-white mb-4 text-sm uppercase tracking-wider">Legal</h4>
            <ul class="space-y-3">
              <li><a href="#" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Privacy</a></li>
              <li><a href="#" class="text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Terms</a></li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div class="border-t border-slate-200 dark:border-slate-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-sm text-slate-500 dark:text-slate-400">
            &copy; {new Date().getFullYear()} Static Sites Builder. All rights reserved.
          </p>
          <p class="text-sm text-slate-500 dark:text-slate-400 flex items-center gap-1">
            <span>Made with</span>
            <svg class="w-4 h-4 text-red-500 fill-current animate-pulse" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            <span>for Myanmar Developers</span>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
  }

  @layer base {
    * {
      scroll-behavior: smooth;
    }

    body {
      transition: background-color 0.3s ease, color 0.3s ease;
      font-family: var(--font-sans);
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }
    .dark ::-webkit-scrollbar-track {
      background: #0f172a;
    }
    ::-webkit-scrollbar-thumb {
      background: #94a3b8;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #64748b;
    }

    /* Selection color */
    ::selection {
      background: #3b82f6;
      color: white;
    }
  }

  @layer utilities {
    .text-gradient {
      @apply bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500;
    }
  }
</style>
