---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/utils';

const lang = 'en';
const title = 'Site Builder — Create Your Website';
const description = 'Build your website with our intuitive site builder. Choose a template, customize content, and deploy instantly.';
---

<Layout title={title} lang={lang} description={description}>
  <!-- Page header -->
  <section class="relative pt-20 sm:pt-28 pb-8 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full bg-gradient-to-br from-blue-400/20 to-purple-400/20 blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-950/50 border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 text-xs font-semibold tracking-wider uppercase mb-4 animate-fade-in-up">
          Site Builder
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight animate-fade-in-up">
          {t(lang, 'builder.title')}
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-300 animate-fade-in-up" style="animation-delay: 0.1s">
          Choose a template below and start building your website in minutes.
        </p>
      </div>
    </div>
  </section>

  <!-- Template selector -->
  <section class="py-12 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filter tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        {['All', 'Portfolio', 'Business', 'Blog', 'Landing', 'E-commerce'].map((tab) => (
          <button class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
            tab === 'All'
              ? 'bg-blue-500 text-white shadow-md shadow-blue-500/25'
              : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 hover:border-blue-300 dark:hover:border-blue-700 hover:text-blue-600'
          }`}>
            {tab}
          </button>
        ))}
      </div>

      <!-- Templates grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {[
          { name: 'Portfolio Pro', desc: 'Showcase your creative work with a stunning portfolio.', badge: 'Popular', badgeColor: 'bg-blue-500' },
          { name: 'Business Starter', desc: 'Professional site for your business or startup.', badge: null, badgeColor: '' },
          { name: 'Blog Studio', desc: 'Clean, reading-optimized blog layout.', badge: 'New', badgeColor: 'bg-green-500' },
          { name: 'Agency Landing', desc: 'High-converting landing page for agencies.', badge: null, badgeColor: '' },
          { name: 'Shop Front', desc: 'Minimal product showcase with Firestore backend.', badge: null, badgeColor: '' },
          { name: 'Resume Builder', desc: 'Stand out with a beautiful online resume.', badge: 'New', badgeColor: 'bg-green-500' },
        ].map((template) => (
          <div class="group relative bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-xl hover:shadow-slate-200/50 dark:hover:shadow-slate-800/50 hover:-translate-y-1 transition-all duration-300">
            {template.badge && (
              <div class={`absolute top-3 right-3 z-10 px-2.5 py-1 rounded-full ${template.badgeColor} text-white text-[10px] font-bold uppercase tracking-wider`}>
                {template.badge}
              </div>
            )}
            <!-- Template preview -->
            <div class="h-48 bg-gradient-to-br from-slate-100 via-blue-50 to-purple-50 dark:from-slate-700 dark:via-slate-700 dark:to-slate-800 p-4 flex items-center justify-center">
              <div class="w-full h-full bg-white dark:bg-slate-600 rounded-lg shadow-inner p-3 flex flex-col gap-2">
                <div class="h-2 w-3/4 bg-slate-200 dark:bg-slate-500 rounded"></div>
                <div class="h-2 w-1/2 bg-slate-200 dark:bg-slate-500 rounded"></div>
                <div class="flex-1 grid grid-cols-2 gap-2 mt-2">
                  <div class="bg-blue-100 dark:bg-blue-900/30 rounded"></div>
                  <div class="bg-purple-100 dark:bg-purple-900/30 rounded"></div>
                </div>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-lg text-slate-900 dark:text-white mb-1">{template.name}</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 mb-4 leading-relaxed">{template.desc}</p>
              <button class="w-full px-4 py-2.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-sm font-semibold rounded-lg hover:shadow-lg hover:shadow-blue-500/25 hover:scale-[1.02] transition-all duration-300">
                Use This Template
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Customization Tools -->
  <section class="py-12 sm:py-20 bg-slate-50/50 dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 lg:mb-16">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          Powerful Customization
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
          Make your site uniquely yours with easy-to-use customization tools.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🎨', title: 'Color Schemes', desc: 'Beautiful, hand-picked color palettes for every style.', gradient: 'from-blue-500 to-cyan-500' },
          { icon: '✍️', title: 'Content Editor', desc: 'Rich text editing with live preview as you type.', gradient: 'from-purple-500 to-pink-500' },
          { icon: '📐', title: 'Layout Builder', desc: 'Drag-and-drop sections to build your perfect page.', gradient: 'from-orange-500 to-red-500' },
          { icon: '🚀', title: 'One-Click Deploy', desc: 'Push to GitHub and deploy to Pages automatically.', gradient: 'from-green-500 to-emerald-500' },
        ].map((tool, i) => (
          <div class="group text-center p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg hover:-translate-y-1 transition-all duration-300" style={`animation-delay: ${i * 0.1}s`}>
            <div class={`w-14 h-14 mx-auto mb-4 rounded-xl bg-gradient-to-br ${tool.gradient} flex items-center justify-center text-2xl shadow-lg group-hover:scale-110 transition-transform duration-300`}>
              {tool.icon}
            </div>
            <h3 class="font-bold text-slate-900 dark:text-white mb-2">{tool.title}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{tool.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-16 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4">
        Ready to launch?
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300 mb-8">
        Pick a template above and start building. No coding required.
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-500 to-purple-600 text-white font-bold text-lg rounded-xl hover:shadow-xl hover:shadow-blue-500/25 hover:scale-[1.03] transition-all duration-300"
      >
        Start Building Now
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  section:nth-child(3) > div > div:nth-child(2) > div {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
