---
import Layout from '../layouts/Layout.astro';
import { t } from '../i18n/utils';

const lang = 'en';
const title = 'Documentation — Static Sites Builder';
const description = 'Learn how to use Static Sites Builder to create beautiful, fast websites. Complete guide to templates, customization, and deployment.';
---

<Layout title={title} lang={lang} description={description}>
  <!-- Page header -->
  <section class="relative pt-20 sm:pt-28 pb-8 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 h-[400px] w-[400px] rounded-full bg-gradient-to-br from-blue-400/20 to-purple-400/20 blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-950/50 border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300 text-xs font-semibold tracking-wider uppercase mb-4">
          Documentation
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          Documentation
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-300">
          Everything you need to know to build amazing static websites.
        </p>
      </div>
    </div>
  </section>

  <!-- Docs content -->
  <section class="py-12 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        <!-- Getting Started -->
        <div class="group p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center text-white text-lg shadow-md">🚀</div>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">Getting Started</h2>
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-4 leading-relaxed">
            Static Sites Builder makes it easy to create beautiful websites without coding. Follow these steps to get started:
          </p>
          <ol class="space-y-3">
            {['Choose a template from our collection', 'Customize colors, fonts, and layout', 'Add your content and images', 'Deploy to GitHub Pages with one click'].map((step, i) => (
              <li class="flex items-start gap-3 text-slate-700 dark:text-slate-200">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-400 flex items-center justify-center text-xs font-bold">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>

        <!-- Templates -->
        <div class="group p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-lg shadow-md">🎨</div>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">Available Templates</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              { name: 'Portfolio', desc: 'Showcase your work and projects' },
              { name: 'Business', desc: 'Professional business website' },
              { name: 'Blog', desc: 'Share your thoughts and ideas' },
              { name: 'Agency', desc: 'Present your services' },
              { name: 'Shop', desc: 'Sell your products online' },
              { name: 'Resume', desc: 'Create an online CV' },
            ].map((t) => (
              <div class="flex items-center gap-3 p-3 rounded-lg bg-slate-50 dark:bg-slate-900/50">
                <span class="font-semibold text-slate-900 dark:text-white text-sm">{t.name}</span>
                <span class="text-xs text-slate-500 dark:text-slate-400">— {t.desc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Customization -->
        <div class="group p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-red-500 flex items-center justify-center text-white text-lg shadow-md">⚡</div>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">Customization</h2>
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-4 leading-relaxed">
            Personalize your website with our easy-to-use customization tools. Edit colors, fonts, spacing, and more directly in the builder with live preview.
          </p>
          <div class="bg-slate-50 dark:bg-slate-900 rounded-lg p-4 font-mono text-sm text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
            <span class="text-purple-500">import</span> {'{'} defineConfig {'}'} <span class="text-purple-500">from</span> <span class="text-green-500">'astro/config'</span>;
            <br />
            <span class="text-slate-400">// All configurable via the builder UI</span>
          </div>
        </div>

        <!-- Deployment -->
        <div class="group p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center text-white text-lg shadow-md">🚀</div>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">Deployment</h2>
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-4 leading-relaxed">
            Deploy your site to GitHub Pages in seconds with automatic CI/CD:
          </p>
          <ol class="space-y-3">
            {['Push your changes to GitHub', 'GitHub Actions builds your site automatically', 'Your site goes live on GitHub Pages', 'Future pushes auto-deploy'].map((step, i) => (
              <li class="flex items-start gap-3 text-slate-700 dark:text-slate-200">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/50 text-green-600 dark:text-green-400 flex items-center justify-center text-xs font-bold">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      </div>

      <!-- Help CTA -->
      <div class="mt-16 p-8 sm:p-10 rounded-2xl bg-gradient-to-r from-blue-500 via-purple-600 to-pink-500 text-white text-center">
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-4">Need Help?</h2>
        <p class="text-blue-100 mb-6 text-lg max-w-lg mx-auto">
          Can't find what you're looking for? Reach out to our support team.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-3 bg-white text-blue-600 font-bold rounded-xl hover:shadow-xl hover:scale-[1.03] transition-all duration-300"
        >
          Contact Support
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
