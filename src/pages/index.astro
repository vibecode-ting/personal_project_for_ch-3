---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import { t } from '../i18n/utils';

const lang = 'en';
const title = 'Static Sites Builder — Build Faster, Deploy Instantly';
const description = 'Create professional static websites with our powerful builder. Firebase-powered, SEO-optimized, and production-ready. Deploy to GitHub Pages in minutes.';
---

<Layout title={title} lang={lang} description={description}>
  <Hero lang={lang} />
  <Features lang={lang} />

  <!-- How It Works Section -->
  <section class="py-20 sm:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 lg:mb-20">
        <span class="inline-block px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-950/50 border border-purple-200 dark:border-purple-800 text-purple-700 dark:text-purple-300 text-xs font-semibold tracking-wider uppercase mb-4">
          How It Works
        </span>
        <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          Three simple steps
        </h2>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
          From idea to live website in under 10 minutes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <div class="relative text-center group">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-2xl font-extrabold shadow-lg group-hover:scale-110 transition-transform duration-300">
            1
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Choose a Template</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Pick from our collection of beautiful, responsive templates designed for every use case.
          </p>
          <!-- Connector line (desktop only) -->
          <div class="hidden md:block absolute top-8 left-[calc(50%+3rem)] w-[calc(100%-6rem)] h-px bg-gradient-to-r from-blue-300 to-purple-300 dark:from-blue-700 dark:to-purple-700"></div>
        </div>

        <div class="relative text-center group">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-purple-500 to-pink-600 flex items-center justify-center text-white text-2xl font-extrabold shadow-lg group-hover:scale-110 transition-transform duration-300">
            2
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Customize Content</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Add your own text, images, and branding. Customize colors and layouts to match your style.
          </p>
          <div class="hidden md:block absolute top-8 left-[calc(50%+3rem)] w-[calc(100%-6rem)] h-px bg-gradient-to-r from-purple-300 to-pink-300 dark:from-purple-700 dark:to-pink-700"></div>
        </div>

        <div class="text-center group">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-pink-500 to-orange-600 flex items-center justify-center text-white text-2xl font-extrabold shadow-lg group-hover:scale-110 transition-transform duration-300">
            3
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Deploy Instantly</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Push to GitHub and deploy automatically to GitHub Pages. Your site goes live in seconds.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials / Social Proof -->
  <section class="py-20 sm:py-32 bg-slate-50/50 dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-block px-3 py-1 rounded-full bg-green-50 dark:bg-green-950/50 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-xs font-semibold tracking-wider uppercase mb-4">
          Testimonials
        </span>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          Loved by developers
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex gap-1 mb-4">
            {['★','★','★','★','★'].map(() => <span class="text-amber-400 text-lg">★</span>)}
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed italic">
            "This builder saved us weeks of development time. We launched our company site in just a few hours."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white font-bold text-sm">AK</div>
            <div>
              <p class="font-semibold text-slate-900 dark:text-white text-sm">Aung Kyaw</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">Full Stack Developer</p>
            </div>
          </div>
        </div>

        <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex gap-1 mb-4">
            {['★','★','★','★','★'].map(() => <span class="text-amber-400 text-lg">★</span>)}
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed italic">
            "The Firebase integration is seamless. Perfect for adding dynamic features to our static site."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center text-white font-bold text-sm">MT</div>
            <div>
              <p class="font-semibold text-slate-900 dark:text-white text-sm">May Thu</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">UI/UX Designer</p>
            </div>
          </div>
        </div>

        <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition-shadow duration-300">
          <div class="flex gap-1 mb-4">
            {['★','★','★','★','★'].map(() => <span class="text-amber-400 text-lg">★</span>)}
          </div>
          <p class="text-slate-600 dark:text-slate-300 mb-6 leading-relaxed italic">
            "The GitHub Pages deployment is set up perfectly. Push to main and it just works. Zero configuration."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-400 to-pink-500 flex items-center justify-center text-white font-bold text-sm">ZK</div>
            <div>
              <p class="font-semibold text-slate-900 dark:text-white text-sm">Zaw Ko</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">DevOps Engineer</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-20 sm:py-32 overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-r from-blue-500 via-purple-600 to-pink-500"></div>
    <!-- Overlay pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:48px_48px]"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 tracking-tight">
        Ready to build your site?
      </h2>
      <p class="text-xl text-blue-100 mb-10 max-w-2xl mx-auto leading-relaxed">
        Join thousands of developers building lightning-fast static websites. Start free, no credit card required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`/${lang}/builder`}
          class="group px-8 py-4 bg-white text-blue-600 font-bold text-lg rounded-xl hover:shadow-2xl hover:scale-[1.03] transition-all duration-300 inline-flex items-center justify-center gap-2"
        >
          Get Started Free
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a
          href={`/${lang}/contact`}
          class="px-8 py-4 border-2 border-white/40 text-white font-bold text-lg rounded-xl hover:bg-white/10 hover:border-white/60 transition-all duration-300"
        >
          Talk to Us
        </a>
      </div>
    </div>
  </section>
</Layout>
